PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/micovi_db
JWT_SECRET=change-me-use-at-least-32-random-characters
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=14
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
# COOKIE_DOMAIN=.midominio.com
CSRF_ENABLED=true
CORS_ORIGINS=["http://localhost:4200","http://127.0.0.1:4200"]

# QA example:
# COOKIE_SECURE=true
# COOKIE_DOMAIN=.midominio.com
# CORS_ORIGINS=["https://qa.midominio.com"]

# PROD example:
# NODE_ENV=production
# COOKIE_SECURE=true
# COOKIE_DOMAIN=.midominio.com
# CORS_ORIGINS=["https://app.midominio.com"]
